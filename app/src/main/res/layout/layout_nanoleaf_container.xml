<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/container_nanoleaf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_section_bridge"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <include
                android:id="@+id/status_nanoleaf"
                layout="@layout/layout_connection_status" />

            <!-- One row per paired device (name · state · forget), built in code. -->
            <LinearLayout
                android:id="@+id/nanoleaf_device_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_nanoleaf_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nanoleaf_hint"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.2"
                android:padding="16dp"
                android:background="@drawable/segment_button_bg"
                android:layout_marginBottom="16dp"
                android:gravity="start" />

            <Button
                android:id="@+id/btn_nanoleaf_scan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/pill_button_bg"
                android:text="Scan for Nanoleaf"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:stateListAnimator="@null" />


            <!-- ── SECTION: LIGHT CONTROL ── -->
            <LinearLayout
                android:id="@+id/nanoleaf_light_control"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View style="@style/DividerSubtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hue_light_control_label"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:textStyle="normal"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/nanoleaf_scene_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hue_brightness_label"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/nanoleaf_brightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:max="100"
                    android:progress="100"
                    android:progressDrawable="@drawable/seekbar_spectrum"
                    android:thumbTint="@color/accent"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>

            <View style="@style/DividerSubtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Sync"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_nanoleaf_sync"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/hue_sync_off"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:enabled="false"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_nanoleaf_advanced"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/adv_button"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone"
                android:stateListAnimator="@null" />

        </LinearLayout>
