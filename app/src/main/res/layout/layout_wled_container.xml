<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/container_wled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_section_bridge"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <include
                android:id="@+id/status_wled"
                layout="@layout/layout_connection_status" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wled_blurb"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.2"
                android:padding="16dp"
                android:background="@drawable/segment_button_bg"
                android:layout_marginBottom="16dp"
                android:gravity="start" />

            <Button
                android:id="@+id/btn_wled_scan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/wled_scan"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <ProgressBar
                android:id="@+id/wled_scan_spinner"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/wled_device_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <View style="@style/DividerSubtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Sync"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_wled_sync"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/hue_sync_off"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:enabled="false"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_wled_advanced"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/adv_button"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone"
                android:stateListAnimator="@null" />

        </LinearLayout>
