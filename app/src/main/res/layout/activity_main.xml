<?xml version="1.0" encoding="utf-8"?>
<!--
  Layer order (bottom -> top):
    1. VisualizerSurfaceView  - the OpenGL canvas (always rendering)
    2. scrim                  - dim + tap-to-dismiss when the menu is open
    3. options_sheet          - translucent settings panel (slides up)
    4. first_boot_overlay     - one-time welcome / controls hint
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.lowlatency.visualizer.VisualizerSurfaceView
        android:id="@+id/gl_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Performance diagnostics overlay (top-left, over GL view) -->
    <TextView
        android:id="@+id/perf_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="40dp"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:fontFamily="@font/space_mono"
        android:lineSpacingMultiplier="1.3"
        android:visibility="gone" />

    <!-- In-app Link notifications (top-center, briefly shown) -->
    <TextView
        android:id="@+id/link_notification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="64dp"
        android:background="@drawable/chip_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Tap-outside / dim scrim (hidden until the menu opens) -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Options sheet: lower portion of the canvas. A ScrollView so the full
         control list (now 8 visualizers) always fits — on short screens it
         scrolls internally instead of pushing the top controls off-screen. -->
    <ScrollView
        android:id="@+id/options_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginTop="72dp"
        android:background="@drawable/sheet_background"
        android:clickable="true"
        android:focusable="true"
        android:fillViewport="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="44dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/text_dim" />

        <!-- Tab bar: Visuals | Lighting | Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/tab_btn_visuals"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/tab_visualizers"
                android:textColor="@color/btn_text"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textSize="11sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_btn_lighting"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/tab_lighting"
                android:textColor="@color/btn_text"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textSize="11sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tab_btn_settings"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/tab_settings"
                android:textColor="@color/btn_text"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textSize="11sp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ===== TAB 1: Visualizers ===== -->
        <LinearLayout
            android:id="@+id/tab_visualizers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- The active "VISUALS" tab already names this section, so the section
             label is dropped; the long-press hint stays for discoverability. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hint_long_press_fav"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:layout_marginBottom="14dp" />

        <!-- Visualizer selector (stacked so full labels fit), grouped by style -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- ===== Category: Instruments (clean, lightweight) ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cat_instruments"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_oscilloscope"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_oscilloscope"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_rawscope"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_rawscope"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_bars"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_bars"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_circular"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_circular"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_spectrogram"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_spectrogram"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_led_matrix"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_led_matrix"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_mechanical_meter"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_mechanical_meter"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_cymatics"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_cymatics"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <!-- ===== Category: Reactive (beat / energy driven) ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@color/sheet_stroke" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cat_reactive"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_beat_pulse"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_beat_pulse"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_fireworks"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_fireworks"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_starscape"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_starscape"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_bloom"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_bloom"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_electric_iris"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_electric_iris"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <!-- ===== Category: Immersive (rich generative, heavier GPU) ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@color/sheet_stroke" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cat_immersive"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_tunnel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_tunnel"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_fluid"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_fluid"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_laser"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_laser"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_phyllotaxis"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_phyllotaxis"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_mandala"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_mandala"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_audio_web"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_audio_web"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_topo_ridge"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_topo_ridge"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_mandelbox"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_mandelbox"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:background="@drawable/chip_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/vis_mandelbox_warning"
                android:textColor="@color/text_dim"
                android:textSize="9sp" />

            <Button
                android:id="@+id/btn_reaction_diffusion"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_reaction_diffusion"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_strange_attractor"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/vis_strange_attractor"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        </LinearLayout>
        <!-- /TAB 1: Visuals -->

        <!-- ===== TAB 3: Settings (audio source · display · beat sensitivity) ===== -->
        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- ===== Group: Audio & Beat ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/source_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <!-- Audio source segmented toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/seg_mic"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/source_mic"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/seg_internal"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/source_internal"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Beat sensitivity (drives fireworks, haptics, starscape flashes) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/beat_sens_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_sens_low"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/beat_sens_low"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_sens_standard"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/beat_sens_standard"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_sens_high"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/segment_button_bg"
                android:text="@string/beat_sens_high"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Vibrate-on-beat haptics toggle -->
        <Button
            android:id="@+id/btn_haptics"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/haptics_off"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <!-- Ableton Link wireless tempo/beat sync -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/link_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_link_sync"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/link_sync_off"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_link_notify"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/link_notifications_on"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/link_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/link_status_off"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <!-- Diagnostic beat light: pulses on every Link beat. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <View
                android:id="@+id/beat_dot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:alpha="0.18"
                android:background="@drawable/beat_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/link_beat_label"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/link_help"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="8dp" />

        <!-- ───── divider: Audio & Beat / Display ───── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@color/sheet_stroke" />

        <!-- ===== Group: Display ===== -->
        <!-- HDR bloom / glow strength -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/glow_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_glow_off"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/glow_off"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_glow_subtle"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/glow_subtle"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_glow_standard"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/glow_standard"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_glow_intense"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/glow_intense"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Theme (global colour grade applied to every visual) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/theme_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_theme_spectrum"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/theme_spectrum"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_theme_neon"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/theme_neon"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_theme_warm"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/theme_warm"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_theme_cool"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/theme_cool"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_theme_mono"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/segment_button_bg"
                android:text="@string/theme_mono"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/display_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <!-- OLED burn-in protection toggle -->
        <Button
            android:id="@+id/btn_burnin"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/burnin_on"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <!-- Performance diagnostics overlay toggle -->
        <Button
            android:id="@+id/btn_perf_overlay"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/perf_overlay_off"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <!-- ───── divider: Display / About ───── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@color/sheet_stroke" />

        <!-- ===== Group: About ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_privacy_policy"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/btn_privacy_policy"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_about"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/btn_about"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        </LinearLayout>
        <!-- /TAB 3: Settings -->

        <!-- ===== TAB 2: Lighting (Philips Hue) ===== -->
        <LinearLayout
            android:id="@+id/tab_lighting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- Philips Hue Branding and Prerequisites -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hue_header_title"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hue_prerequisites"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.2"
            android:padding="12dp"
            android:background="@drawable/segment_button_bg"
            android:layout_marginBottom="16dp" />

        <!-- Live connection-state indicator (dot colored in code) -->
        <TextView
            android:id="@+id/hue_conn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hue_conn_disconnected"
            android:textColor="@color/text_dim"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <!-- Local-only note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hue_local_note"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_hue_connect"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/hue_connect"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:stateListAnimator="@null" />

        <!-- Dynamically populated list of Entertainment Areas -->
        <LinearLayout
            android:id="@+id/hue_area_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_hue_sync"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/hue_sync_off"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:enabled="false"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/hue_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/hue_status_idle"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:layout_marginBottom="16dp" />

        <!-- Advanced light tuning (shown only while Hue sync is active). -->
        <Button
            android:id="@+id/btn_advanced"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/pill_button_bg"
            android:text="@string/adv_button"
            android:textColor="@color/btn_text"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:visibility="gone"
            android:stateListAnimator="@null" />

        </LinearLayout>
        <!-- /TAB 2 -->

        </LinearLayout>
    </ScrollView>

    <!-- First-boot welcome / controls hint -->
    <FrameLayout
        android:id="@+id/first_boot_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/first_boot_scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_title"
                android:textColor="@color/btn_text"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_swipe_sides"
                android:textColor="@color/btn_text"
                android:textSize="16sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_swipe_up"
                android:textColor="@color/btn_text"
                android:textSize="16sp"
                android:layout_marginBottom="48dp" />

            <Button
                android:id="@+id/btn_understood"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="160dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/understood"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </FrameLayout>

    <!-- Startup splash: ASCII-style VELO logo over black; fades out (topmost) -->
    <LinearLayout
        android:id="@+id/splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <com.lowlatency.visualizer.AsciiLogoView
            android:id="@+id/splash_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_tagline"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <!-- Brief intro hint (fades out after a few seconds) -->
    <LinearLayout
        android:id="@+id/intro_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="64dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="@drawable/sheet_background"
        android:alpha="0"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_swipe_sides"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_swipe_up"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />
    </LinearLayout>

</FrameLayout>
