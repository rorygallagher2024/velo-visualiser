<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/container_hue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- ── SECTION: BRIDGE ── -->
        <LinearLayout
            android:id="@+id/hue_section_bridge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_section_bridge"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <include
                android:id="@+id/status_hue"
                layout="@layout/layout_connection_status" />

            <TextView
                android:id="@+id/hue_prerequisites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hue_prerequisites"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.2"
                android:padding="16dp"
                android:background="@drawable/segment_button_bg"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/hue_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="start"
                android:text="@string/hue_status_idle"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_hue_connect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/pill_button_bg"
                android:stateListAnimator="@null"
                android:text="@string/hue_connect"
                android:textAllCaps="false"
                android:textColor="@color/btn_text"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ── SECTION: ENTERTAINMENT AREA ── -->
        <LinearLayout
            android:id="@+id/hue_section_areas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View style="@style/DividerSubtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_section_areas"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/hue_area_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- ── SECTION: LIGHT CONTROL ── -->
        <LinearLayout
            android:id="@+id/hue_light_control"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View style="@style/DividerSubtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_light_control_label"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/hue_scene_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_brightness_label"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp" />

            <SeekBar
                android:id="@+id/hue_brightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:max="100"
                android:progress="100"
                android:progressDrawable="@drawable/seekbar_spectrum"
                android:thumbTint="@color/accent"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

        <!-- ── SECTION: AUDIO SYNC ── -->
        <LinearLayout
            android:id="@+id/hue_section_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View style="@style/DividerSubtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hue_section_sync"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="normal"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_hue_sync"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/hue_sync_off"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:enabled="false"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_advanced"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/pill_button_bg"
                android:text="@string/adv_button"
                android:textColor="@color/btn_text"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone"
                android:stateListAnimator="@null" />

        </LinearLayout>
        </LinearLayout>
