<?xml version="1.0" encoding="utf-8"?>
<!-- Selectable-button label colour. Inverts to dark ink when the button is
     filled (selected/pressed); otherwise warm off-white on the dark panel. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true" android:color="@color/seg_text_selected" />
    <item android:state_pressed="true" android:color="@color/seg_text_selected" />
    <item android:color="@color/text_primary" />
</selector>
