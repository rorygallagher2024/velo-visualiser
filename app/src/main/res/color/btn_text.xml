<?xml version="1.0" encoding="utf-8"?>
<!-- Selectable-button label colour. Inverts to dark ink when the button is
     filled (selected/pressed) — higher contrast on the orange than white, and
     truer to the OP-1's dark-on-light keycaps; otherwise warm off-white. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/text_dim" />
    <item android:state_pressed="true" android:color="@color/ink_invert" />
    <item android:state_selected="true" android:color="@color/ink_invert" />
    <item android:color="@color/text_primary" />
</selector>
