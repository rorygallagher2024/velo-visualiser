<?xml version="1.0" encoding="utf-8"?>
<!-- Small inline tag/chip: faint fill + hairline, for caption badges such as
     the "high-end device" note under a heavy visual. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/segment_idle" />
    <corners android:radius="5dp" />
    <stroke android:width="1dp" android:color="@color/sheet_stroke" />
</shape>
