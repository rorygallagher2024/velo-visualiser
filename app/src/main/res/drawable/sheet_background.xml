<?xml version="1.0" encoding="utf-8"?>
<!-- Translucent frosted panel with rounded top corners for the options sheet. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/sheet_fill" />
    <corners
        android:topLeftRadius="24dp"
        android:topRightRadius="24dp" />
    <stroke
        android:width="1dp"
        android:color="@color/sheet_stroke" />
</shape>
