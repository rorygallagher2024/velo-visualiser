<?xml version="1.0" encoding="utf-8"?>
<!-- Space Mono (OFL) — the geometric monospace behind the Teenage-Engineering
     style UI. Mapped so normal/bold resolve to the bundled static weights. -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/space_mono_regular" />
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/space_mono_bold" />
</font-family>
