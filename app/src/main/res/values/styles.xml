<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Shared look for the full-width "pill" scene buttons in the settings sheet.
         A scene button only needs an id + text; the last button in each category
         overrides android:layout_marginBottom to 16dp for the inter-section gap. -->
    <style name="VisualizerPill">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/pill_button_bg</item>
        <item name="android:textColor">@color/btn_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Shared look for segmented (multi-button row) controls in the settings
         sheet.  Each button only needs an id + text; override margins per-use.
         Text is 12sp so it fits 3–5 buttons in a row on small screens. -->
    <style name="SegmentButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/segment_button_bg</item>
        <item name="android:textColor">@color/btn_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Settings-sheet section/category label (e.g. "INSTRUMENTS", "AUDIO").
         Defaults to a left-aligned wrap_content label; the full-width category
         headers override layout_width + layout_marginBottom. -->
    <style name="SectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Subordinate heading nested under a SectionHeader (e.g. Beat Sensitivity,
         Ableton Link inside Beat Detection): smaller, dimmer, with breathing room. -->
    <style name="SubHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:alpha">0.6</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- Solid 1dp section rule. Margins are set per-use. -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/sheet_stroke</item>
    </style>

    <!-- Faint 1dp rule (dimmed text colour) used inside sections. -->
    <style name="DividerSubtle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/text_dim</item>
        <item name="android:alpha">0.25</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">14dp</item>
    </style>

</resources>
