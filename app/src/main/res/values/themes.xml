<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.LowLatencyVisualizer" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/scope_background</item>
        <item name="android:statusBarColor">@color/scope_background</item>
        <item name="android:navigationBarColor">@color/scope_background</item>
        <!-- App-wide grotesque (Inter). Space Mono is kept
             for numeric/technical readouts (perf overlay, Link BPM/peers). -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
    </style>

    <!-- Immersive fullscreen variant for the visualizer surface. -->
    <style name="Theme.LowLatencyVisualizer.Fullscreen" parent="Theme.LowLatencyVisualizer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Dark themed dialog for Privacy Policy -->
    <style name="Theme.LowLatencyVisualizer.Dialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/sheet_fill</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_dim</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <!-- Splash screen theme for Android 12+ compatibility. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.LowLatencyVisualizer.Fullscreen</item>
    </style>
</resources>
